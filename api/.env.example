# Copy to api/.env and fill in. api/.env is gitignored.

# Google Gemini (required for real AI output; without it the engine runs in mock mode)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# Database — SQLite for local dev, Postgres in production
DATABASE_URL=sqlite:///./educlip_dev.db

# Background processing — false (dev) runs tasks in-process; true requires Redis + Celery worker
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0

# Stripe (mock values work for local dev)
STRIPE_SECRET_KEY=sk_test_mock_key
STRIPE_WEBHOOK_SECRET=whsec_mock_secret
